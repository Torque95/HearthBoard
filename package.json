{
  "name": "hearthboard",
  "version": "1.0.0",
  "description": "HearthBoard — Your family's living dashboard",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^25.9.8",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hearthboard.app",
    "productName": "HearthBoard",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "node_modules/**/*"],
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png",
      "category": "Utility"
    }
  }
}
